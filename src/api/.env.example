# Deepgram API Configuration
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US

# Server Configuration  
PORT=3000
NODE_ENV=production
API_VERSION=v1

# Security
# CORS — required in production, must not be "*". Comma-separated for multiple origins.
# Defaults to http://localhost:3000 in development.
CORS_ORIGIN=http://localhost:3000
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100
TRANSCRIPTION_RATE_LIMIT_MAX_REQUESTS=20

# File Upload Limits
MAX_FILE_SIZE_MB=50
MAX_UPLOAD_DURATION_SECONDS=3600

# Logging Configuration
LOG_LEVEL=info
LOG_RETENTION_DAYS=30

# Health Check Configuration
HEALTH_CHECK_TIMEOUT_MS=5000

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL_MS=30000
WS_CONNECTION_TIMEOUT_MS=300000

# Monitoring (Optional)
SENTRY_DSN=your_sentry_dsn_here
NEW_RELIC_LICENSE_KEY=your_new_relic_key_here

# Database (Optional - for request logging)
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:password@localhost:5432/muesli_api