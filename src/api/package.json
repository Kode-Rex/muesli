{
  "name": "muesli-transcription-api",
  "version": "1.0.0",
  "description": "Production-ready API server for Muesli app transcription services with Deepgram integration",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage --passWithNoTests",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest tests/unit --coverage",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest tests/integration --coverage",
    "test:ci": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage --ci --watchAll=false --passWithNoTests --forceExit --runInBand",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "health": "curl -f http://localhost:3000/health || exit 1",
    "docker:build": "docker build -t muesli-api .",
    "docker:run": "docker run -p 3000:3000 --env-file .env muesli-api"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@deepgram/sdk": "^3.4.0",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.1",
    "express-slow-down": "^3.1.0",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "pg-mem": "^3.0.14",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "transcription",
    "deepgram",
    "api",
    "speech-to-text",
    "websocket",
    "production"
  ],
  "author": "Travis Frisinger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kode-Rex/muesli.git"
  }
}
